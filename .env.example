# Neon PostgreSQL connection string (required for analysis history)
# Get yours free at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Clerk authentication (required)
# Get yours free at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# LLM for blood report extraction (OpenAI-compatible API)
# Cloud: DeepSeek (default) — get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=your_key_here

# Local model override (uncomment to use Ollama, LM Studio, etc.)
# No API key needed for local models.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b
